{
  "name": "@pos-pyme/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node --transpile-only -r tsconfig-paths/register src/main.ts",
    "dev:watch": "ts-node-dev --respawn --transpile-only -r tsconfig-paths/register src/main.ts",
    "build": "nest build",
    "start": "node dist/main.js",
    "start:prod": "node dist/main.js",
    "lint": "eslint . --max-warnings 999",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo",
    "lint:fix": "eslint . --fix",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.0",
    "@nestjs/core": "^10.3.0",
    "@nestjs/platform-express": "^10.3.0",
    "@pos-pyme/business-rules": "workspace:*",
    "@pos-pyme/supabase-types": "workspace:*",
    "@pos-pyme/validation": "workspace:*",
    "@supabase/supabase-js": "^2.43.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "jose": "^6.2.3",
    "jsonwebtoken": "^9.0.2",
    "reflect-metadata": "^0.2.0",
    "resend": "^6.16.0",
    "rxjs": "^7.8.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.3.0",
    "@nestjs/schematics": "^10.1.0",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.0",
    "ts-node": "^10.9.0",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  }
}
