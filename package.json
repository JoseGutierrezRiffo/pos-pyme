{
  "name": "pos-pyme",
  "version": "0.1.0",
  "private": true,
  "description": "POS, inventario y turnos para micro-PYMEs",
  "type": "module",
  "packageManager": "pnpm@8.10.2",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "turbo run build",
    "clean": "turbo run clean && rm -rf node_modules .turbo",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "gen:types": "supabase gen types typescript --project-id $SUPABASE_PROJECT_ID --schema public > packages/supabase-types/src/database.ts",
    "setup": "pnpm install && pnpm setup:db && pnpm build",
    "dev": "turbo run dev",
    "dev:api": "turbo run dev --filter=@pos-pyme/api",
    "dev:admin": "turbo run dev --filter=@pos-pyme/web-admin",
    "dev:worker": "turbo run dev --filter=@pos-pyme/web-worker",
    "dev:fe": "turbo run dev --filter=@pos-pyme/web-admin --filter=@pos-pyme/web-worker",
    "dev:worker-api": "turbo run dev --filter=@pos-pyme/api --filter=@pos-pyme/web-worker",
    "dev:admin-api": "turbo run dev --filter=@pos-pyme/api --filter=@pos-pyme/web-admin",
    "dev:fresh": "pnpm ports:kill && pnpm dev",
    "ports:check": "lsof -i :3000,5173,5174 2>/dev/null || echo '\u2705 Puertos libres'",
    "ports:kill": "lsof -ti :3000,5173,5174 2>/dev/null | xargs kill -9 2>/dev/null; echo '\ud83e\uddf9 Puertos limpiados'",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "setup:db": "supabase db push"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jest-axe": "^10.0.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.3.0",
    "turbo": "^2.0.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.62.1",
    "vitest": "^2"
  },
  "pnpm": {
    "overrides": {
      "vitest@>=2.1.0 <3.2.6": "~3.2.6",
      "@vitest/ui": "~3.2.6",
      "@vitest/coverage-v8": "~3.2.6",
      "glob@>=10.2.0 <10.5.0": ">=10.5.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4",
      "tmp@<0.2.6": ">=0.2.6",
      "vite@<=6.4.2": ">=6.4.3",
      "lodash@<=4.17.23": ">=4.17.24",
      "multer@<2.2.0": ">=2.2.0",
      "qs": ">=6.14.1",
      "file-type": ">=21.3.1",
      "webpack": ">=5.104.0"
    },
    "peerDependencyRules": {
      "allowedVersions": {
        "eslint": "9"
      }
    }
  }
}
